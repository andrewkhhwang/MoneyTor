generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User & Authentication
// ============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String? // Hashed password for credential auth
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts     Account[]
  transactions Transaction[]
  categories   Category[]
  budgets      Budget[]
  institutions Institution[]
  connections  UserConnection[]

  // NextAuth relations
  authAccounts AuthAccount[]
  sessions     Session[]

  @@map("users")
}

// NextAuth.js required models
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// Plaid Integration
// ============================================================================

model Institution {
  id                    String   @id @default(cuid())
  userId                String
  provider              String   @default("plaid") // 'plaid' or future providers
  providerInstitutionId String // Plaid institution_id
  name                  String
  logo                  String? // Institution logo URL
  primaryColor          String? // Brand color
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]

  @@unique([userId, providerInstitutionId])
  @@map("institutions")
}

model UserConnection {
  id          String   @id @default(cuid())
  userId      String
  provider    String   @default("plaid")
  itemId      String // Plaid item_id
  accessToken String // Encrypted Plaid access_token
  cursor      String? // For transaction sync pagination
  status      String   @default("active") // 'active', 'needs_attention', 'disconnected'
  errorCode   String? // Plaid error code if status is not active
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@map("user_connections")
}

// ============================================================================
// Financial Accounts
// ============================================================================

model Account {
  id                String   @id @default(cuid())
  userId            String
  institutionId     String?
  name              String
  officialName      String? // From Plaid
  type              String // 'checking', 'savings', 'credit_card', 'investment', 'loan', 'mortgage', 'manual_cash'
  subtype           String? // More specific type from Plaid
  currency          String   @default("USD")
  startingBalance   Decimal  @default(0) @db.Decimal(19, 4)
  currentBalance    Decimal? @db.Decimal(19, 4) // Last known balance
  availableBalance  Decimal? @db.Decimal(19, 4)
  creditLimit       Decimal? @db.Decimal(19, 4) // For credit cards
  providerAccountId String? // Plaid account_id
  mask              String? // Last 4 digits of account number
  isSyncEnabled     Boolean  @default(false)
  isHidden          Boolean  @default(false) // Hide from dashboard
  lastSyncedAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution  Institution?             @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  snapshots    AccountBalanceSnapshot[]

  @@unique([userId, providerAccountId])
  @@map("accounts")
}

model AccountBalanceSnapshot {
  id        String   @id @default(cuid())
  accountId String
  balance   Decimal  @db.Decimal(19, 4)
  date      DateTime @db.Date

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("account_balance_snapshots")
}

// ============================================================================
// Categories & Budgets
// ============================================================================

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String? // Emoji or icon name
  color     String? // Hex color for charts
  type      String // 'income' | 'expense'
  isSystem  Boolean  @default(false) // System-generated categories
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  rules        CategoryRule[]

  @@unique([userId, name, type])
  @@map("categories")
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  period     String // 'YYYY-MM' format
  amount     Decimal  @db.Decimal(19, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period])
  @@map("budgets")
}

// ============================================================================
// Transactions
// ============================================================================

model Transaction {
  id                    String   @id @default(cuid())
  userId                String
  accountId             String
  categoryId            String?
  type                  String // 'income' | 'expense' | 'transfer'
  amount                Decimal  @db.Decimal(19, 4) // Always positive, type determines direction
  date                  DateTime @db.Date
  description           String?
  notes                 String?
  relatedTransactionId  String? // For transfer pairs
  isRecurring           Boolean  @default(false)
  recurringRuleId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Plaid-synced transaction fields
  providerTransactionId String?  @unique // Plaid transaction_id
  originalDescription   String? // Raw description from bank
  merchantName          String?
  pending               Boolean  @default(false)
  plaidCategory         String[] // Plaid category hierarchy
  plaidCategoryId       String? // Plaid personal_finance_category
  isManuallyEdited      Boolean  @default(false) // User overrode synced data

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([accountId, date])
  @@map("transactions")
}

// ============================================================================
// Category Rules (for auto-categorization)
// ============================================================================

model CategoryRule {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  matchType   String // 'contains', 'exact', 'starts_with', 'regex'
  matchValue  String // The pattern to match against description/merchant
  matchField  String   @default("description") // 'description', 'merchant', 'both'
  priority    Int      @default(0) // Higher priority rules run first
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_rules")
}

// ============================================================================
// Recurring Transactions
// ============================================================================

model RecurringRule {
  id          String    @id @default(cuid())
  userId      String
  accountId   String
  categoryId  String?
  type        String // 'income' | 'expense'
  amount      Decimal   @db.Decimal(19, 4)
  description String
  frequency   String // 'daily', 'weekly', 'biweekly', 'monthly', 'yearly'
  dayOfMonth  Int? // For monthly: 1-31
  dayOfWeek   Int? // For weekly: 0-6 (Sun-Sat)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  nextDueDate DateTime  @db.Date
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("recurring_rules")
}
